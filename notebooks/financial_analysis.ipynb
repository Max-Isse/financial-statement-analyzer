import pandas as pd
import matplotlib.pyplot as plt

data = pd.read_csv("../data/company_financials.csv")

data["Revenue_Growth"] = data["Revenue"].pct_change()

print(data)

plt.plot(data["Year"], data["Revenue"])
plt.title("Revenue Growth Over Time")
plt.xlabel("Year")
plt.ylabel("Revenue")

plt.savefig("../visuals/revenue_growth.png")
plt.show()